{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Run event log entry",
  "description": "One JSON object per line in registry/runs.jsonl. Append-only via infra/append_run.py.",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "bet_id",
    "candidate_id",
    "command",
    "machine",
    "git_commit",
    "encoder",
    "cnf_sha256",
    "sr_audit",
    "solver",
    "solver_version",
    "seed",
    "status",
    "wall_seconds"
  ],
  "properties": {
    "run_id":         {"type": "string"},
    "timestamp":      {"type": "string", "format": "date-time"},
    "bet_id":         {"type": "string"},
    "candidate_id":   {"type": "string"},
    "kernel_id":      {"type": "string"},
    "command":        {"type": "string"},
    "machine":        {"type": "string"},
    "git_commit":     {"type": "string"},
    "encoder":        {"type": "string"},
    "cnf_sha256":     {"type": "string"},
    "sr_audit":       {"type": "string", "description": "Output of audit_cnf.py — sr-level + confirmation flag"},
    "solver":         {"type": "string"},
    "solver_version": {"type": "string"},
    "seed":           {"type": "integer"},
    "status":         {"type": "string", "enum": ["SAT", "UNSAT", "TIMEOUT", "KILLED", "ERROR"]},
    "wall_seconds":   {"type": "number"},
    "cpu_seconds":    {"type": "number"},
    "artifacts":      {"type": "array", "items": {"type": "string"}},
    "notes":          {"type": "string"}
  }
}
